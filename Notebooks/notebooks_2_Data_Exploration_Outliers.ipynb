## 2.2 Unique Facies, Aquifer Classes, and Locations
print("Facies:", litho_df['Facies Name\n(Standard)'].unique())
print("Aquifer Classes:", litho_df['Aquifer\nClass'].unique())
print("Locations:", litho_df['Location'].unique())

## 2.3 Plot Thickness Distribution
plt.figure(figsize=(8, 4))
sns.histplot(litho_df["Thickness\n(ft)"], bins=20, color='skyblue')
plt.title("Lithologic Layer Thickness Distribution")
plt.xlabel("Thickness (ft)")
plt.show()

## 2.4 Outlier Analysis (By Thickness, Negative Depths)
thick_outliers = litho_df[litho_df["Thickness\n(ft)"] > litho_df["Thickness\n(ft)"].quantile(0.99)]
print("Extreme Thickness Outliers:\n", thick_outliers)

negative_depth = litho_df[(litho_df["MD Top\n(ft)"] < 0) | (litho_df["MD Base\n(ft)"] < 0)]
print("Negative Depths:\n", negative_depth)

missing_coords = wells_df[wells_df["Surface X"].isnull() | wells_df["Surface Y"].isnull()]
if not missing_coords.empty:
    print("Wells with missing coordinates:\n", missing_coords)