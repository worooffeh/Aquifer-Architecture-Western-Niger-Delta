# # 3. Stratigraphic Correlation - 2D Cross-Sections

## 3.1 Merge Litho and Location Data for Plotting
coord_df = wells_df.rename(columns={'Name': 'Well Name'})
merged = pd.merge(litho_df, coord_df, on="Well Name", how="left")

## 3.2 Convert DMS Latitude to Decimal Degrees for Sorting
import re
def dms_to_dd(s):
    nums = re.findall(r'[\d\.]+', str(s))
    if len(nums) == 4:
        d, m, s, _ = [float(x) for x in nums]
        return d + m/60 + s/3600
    elif len(nums) == 3:
        d, m, s = [float(x) for x in nums]
        return d + m/60 + s/3600
    else:
        return np.nan

merged["Latitude_dd"] = merged["Latitude  "].apply(dms_to_dd)

# North-south order
well_order = (
    merged.groupby("Well Name")["Latitude_dd"]
    .mean()
    .sort_values(ascending=False)
    .index.tolist()
)

## 3.3 Cross-section Plot (Pinch-outs, Horizons)
plt.figure(figsize=(max(10, len(well_order)*1.5), 7))
color_map = {
    'TS':'saddlebrown','FS':'khaki','MS':'goldenrod','CS':'yellow','CL':'lightgray',
    'GR':'peru', 'LG':'dimgray', 'SI-FS':'mediumorchid', 'MS-CS':'orange', 'CL-FS':'teal','FS-MS':'olive',
    'CS-GR':'red'
}
for i, well in enumerate(well_order):
    section = merged[merged['Well Name'] == well]
    for _, row in section.iterrows():
        color = color_map.get(row['Facies Code'], 'green')
        plt.fill_betweenx(
            [row["MD Top\n(ft)"], row["MD Base\n(ft)"]], i-0.4, i+0.4,
            color=color, edgecolor='black'
        )
        plt.text(i, 0.5*(row["MD Top\n(ft)"]+row["MD Base\n(ft)"]), row['Facies Code'],
                 fontsize=7, ha='center', va='center')
plt.gca().invert_yaxis()
plt.xticks(range(len(well_order)), well_order, rotation=90)
plt.xlabel("Well (North → South)")
plt.ylabel("Depth (ft)")
plt.title("Stratigraphic Correlation: North-South Cross Section")
plt.tight_layout()
plt.show()

