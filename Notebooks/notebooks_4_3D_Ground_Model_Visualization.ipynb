## 4.1 Prepare 3D Points for Each Layer
pts = []
vals = []
for _, row in merged.iterrows():
    x, y = row['Surface X'], row['Surface Y']
    for z in np.arange(row["MD Top\n(ft)"], row["MD Base\n(ft)"], 2):
        pts.append([x, y, -z])  # Negative z for typical downwards depth
        vals.append({
            "facies": row["Facies Name\n(Standard)"],
            "aquifer": row["Aquifer\nClass"],
            "well": row["Well Name"]
        })
points = np.array(pts)

## 4.2 3D Borehole Display with PyVista
pv.set_jupyter_backend('pythreejs')
plotter = pv.Plotter()
for well in well_order:
    well_pts = merged[merged['Well Name'] == well]
    for _, row in well_pts.iterrows():
        p1 = [row['Surface X'], row['Surface Y'], -row["MD Top\n(ft)"]]
        p2 = [row['Surface X'], row['Surface Y'], -row["MD Base\n(ft)"]]
        tube = pv.Line(p1, p2).tube(radius=30)
        color = color_map.get(row['Facies Code'], 'green')
        plotter.add_mesh(tube, color=color, label=row["Facies Name\n(Standard)"])
plotter.show()

## 4.3 Overlay Digital Elevation Model (DEM)
# Optional: Only run if DEM is present in data
try:
    import rasterio
    with rasterio.open('../dem/niger_delta_dem.tif') as src:
        arr = src.read(1)
        xs = np.linspace(src.bounds.left, src.bounds.right, arr.shape[1])
        ys = np.linspace(src.bounds.top, src.bounds.bottom, arr.shape[0])
        X, Y = np.meshgrid(xs, ys)
        Z = arr
        dem_surf = pv.StructuredGrid(X, Y, Z)
        plotter.add_mesh(dem_surf, opacity=0.4)
        plotter.show()
except Exception as e:
    print("DEM overlay skipped:", e)

